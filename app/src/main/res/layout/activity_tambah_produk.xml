<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FCFAFF"
    tools:context=".produk.TambahProdukActivity">

    <!-- App Bar -->
    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:elevation="0dp"
        android:background="#FCFAFF">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:navigationIcon="?homeAsUpIndicator">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tambah Produk"
                    android:textColor="#1D1B20"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Elzio Coffee"
                    android:textColor="#49454E"
                    android:textSize="12sp" />
            </LinearLayout>
        </androidx.appcompat.widget.Toolbar>
    </com.google.android.material.appbar.AppBarLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Title Section -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Tambah Produk"
                android:textAlignment="center"
                android:textColor="#1D1B20"
                android:textSize="24sp"
                android:textStyle="bold"
                android:layout_marginBottom="24dp" />

            <!-- Subtitle "Tambah Foto Produk" / Galeri, Camera -->
            <!-- ModelProduk: fotoProduk -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="220dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="#CAC4D0"
                android:layout_marginBottom="24dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:background="#E8DEF8">

                    <!-- Image Preview Area -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:orientation="vertical">

                        <ImageView
                            android:id="@+id/img_preview"
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:src="@android:drawable/ic_menu_camera"
                            app:tint="#4A4458"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:text="Tambah Foto Produk"
                            android:textColor="#4A4458"
                            android:textSize="14sp" />
                    </LinearLayout>

                    <!-- Camera & Gallery Buttons Panel -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:padding="12dp"
                        android:background="#4A4458">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_kamera"
                            style="@style/Widget.MaterialComponents.Button"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginEnd="6dp"
                            app:backgroundTint="#E8DEF8"
                            android:text="Kamera"
                            android:textColor="#4A4458"
                            app:icon="@android:drawable/ic_menu_camera"
                            app:iconTint="#4A4458"
                            app:cornerRadius="24dp"/>

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_galeri"
                            style="@style/Widget.MaterialComponents.Button"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="6dp"
                            app:backgroundTint="#E8DEF8"
                            android:text="Galeri"
                            android:textColor="#4A4458"
                            app:icon="@android:drawable/ic_menu_gallery"
                            app:iconTint="#4A4458"
                            app:cornerRadius="24dp"/>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Informasi Dasar -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Informasi Dasar"
                android:textColor="#6750A4"
                android:textStyle="bold"
                android:layout_marginBottom="12dp"/>

            <!-- ModelProduk: namaProduk -->
            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:boxCornerRadiusTopStart="8dp"
                app:boxCornerRadiusTopEnd="8dp"
                app:boxCornerRadiusBottomStart="8dp"
                app:boxCornerRadiusBottomEnd="8dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_nama_produk"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Nama Produk"
                    android:inputType="text" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Dapat disimpan di ModelProduk: deskripsiProduk -->
            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:boxCornerRadiusTopStart="8dp"
                app:boxCornerRadiusTopEnd="8dp"
                app:boxCornerRadiusBottomStart="8dp"
                app:boxCornerRadiusBottomEnd="8dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_sku"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="SKU (Opsional)"
                    android:inputType="text" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Dapat disimpan di ModelProduk: deskripsiProduk -->
            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:boxCornerRadiusTopStart="8dp"
                app:boxCornerRadiusTopEnd="8dp"
                app:boxCornerRadiusBottomStart="8dp"
                app:boxCornerRadiusBottomEnd="8dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_barcode"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Barcode (Opsional)"
                    android:inputType="text" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Kategori -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Kategori"
                android:textColor="#6750A4"
                android:textStyle="bold"
                android:layout_marginBottom="12dp"/>

            <!-- ModelProduk: idKategori -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_pilih_kategori"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginBottom="24dp"
                android:text="Pilih Kategori"
                android:textColor="#6750A4"
                app:strokeColor="#6750A4"
                app:cornerRadius="28dp" />

            <!-- Cabang -- >
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Cabang"
                android:textColor="#6750A4"
                android:textStyle="bold"
                android:layout_marginBottom="12dp"/>

            <!-- ModelProduk: idCabang -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_pilih_cabang"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginBottom="24dp"
                android:text="Pilih Cabang"
                android:textColor="#6750A4"
                app:strokeColor="#6750A4"
                app:cornerRadius="28dp" />

            <!-- Harga & Keuntungan -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Harga \u0026 Keuntungan"
                android:textColor="#6750A4"
                android:textStyle="bold"
                android:layout_marginBottom="12dp"/>

            <!-- ModelProduk: hargaBeli -->
            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:boxCornerRadiusTopStart="8dp"
                app:boxCornerRadiusTopEnd="8dp"
                app:boxCornerRadiusBottomStart="8dp"
                app:boxCornerRadiusBottomEnd="8dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_harga_beli"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Harga Beli"
                    android:inputType="number" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- ModelProduk: tipeKeuntungan -->
            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:hint="Tipe Keuntungan"
                app:boxCornerRadiusTopStart="8dp"
                app:boxCornerRadiusTopEnd="8dp"
                app:boxCornerRadiusBottomStart="8dp"
                app:boxCornerRadiusBottomEnd="8dp">

                <AutoCompleteTextView
                    android:id="@+id/spinner_tipe_keuntungan"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="none"
                    android:text="Persentase (%)" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:boxCornerRadiusTopStart="8dp"
                app:boxCornerRadiusTopEnd="8dp"
                app:boxCornerRadiusBottomStart="8dp"
                app:boxCornerRadiusBottomEnd="8dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_nilai_profit"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Nilai Profit"
                    android:inputType="numberDecimal" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- ModelProduk: hargaJual -->
            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:boxCornerRadiusTopStart="8dp"
                app:boxCornerRadiusTopEnd="8dp"
                app:boxCornerRadiusBottomStart="8dp"
                app:boxCornerRadiusBottomEnd="8dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_harga_jual"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Harga Jual"
                    android:textStyle="bold"
                    android:textColor="@android:color/black"
                    android:inputType="number" />
            </com.google.android.material.textfield.TextInputLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="(Otomatis terhitung)"
                android:textSize="12sp"
                android:textColor="#49454E"
                android:layout_marginBottom="24dp"
                android:layout_marginTop="4dp"/>

            <!-- Manajemen Stok -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Manajemen Stok"
                android:textColor="#6750A4"
                android:textStyle="bold"
                android:layout_marginBottom="12dp"/>

            <!-- ModelProduk: stokProduk -->
            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                app:boxCornerRadiusTopStart="8dp"
                app:boxCornerRadiusTopEnd="8dp"
                app:boxCornerRadiusBottomStart="8dp"
                app:boxCornerRadiusBottomEnd="8dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_stok"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Stok"
                    android:inputType="number" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- ModelProduk: tanpaBatas -->
            <com.google.android.material.checkbox.MaterialCheckBox
                android:id="@+id/cb_stok_tanpa_batas"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Stok Tak Terbatas"
                android:textSize="14sp"
                android:textColor="#49454E"
                android:layout_marginBottom="32dp" />

            <!-- Simpan Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_simpan"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="Simpan"
                android:textColor="@android:color/white"
                app:backgroundTint="#6750A4"
                app:cornerRadius="28dp"
                android:layout_marginBottom="32dp"/>

        </LinearLayout>
    </ScrollView>
</LinearLayout>