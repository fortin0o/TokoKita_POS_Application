<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.AplikasiKedua">

        <!-- KATEGORI -->
        <activity
            android:name="kategori.DataKategoriActivity"
            android:exported="false" />

        <activity
            android:name="kategori.ModKategoriActivity"
            android:exported="false" />

        <!-- 🔥 PRODUK -->
        <activity
            android:name="kategori.DataProdukActivity"
            android:exported="false" />

        <activity
            android:name="kategori.TambahProdukActivity"
            android:exported="false" />

        <activity
            android:name="kategori.DataPegawaiActivity"
            android:exported="false" />

        <activity
            android:name="kategori.TambahPegawaiActivity"
            android:exported="false" />

        <activity
            android:name="kategori.DataCabangActivity"
            android:exported="false" />

        <activity
            android:name="kategori.TambahCabangActivity"
            android:exported="false" />

        <activity
            android:name="kategori.SettingsActivity"
            android:exported="false" />

        <activity
            android:name="kategori.CheckoutActivity"
            android:exported="false" />

        <activity
            android:name="kategori.ReceiptActivity"
            android:exported="false" />

        <activity
            android:name="kategori.PrinterActivity"
            android:exported="false" />

        <activity
            android:name="kategori.DataTransaksiActivity"
            android:exported="false" />

        <activity
            android:name="kategori.DataPelangganActivity"
            android:exported="false" />

        <activity
            android:name="kategori.TambahPelangganActivity"
            android:exported="false" />

        <activity
            android:name="kategori.LaporanActivity"
            android:exported="false" />

        <!-- MAIN -->
        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

    </application>


</manifest>